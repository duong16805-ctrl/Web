@model Web.Models.Supplier
@{
    ViewBag.Title = "Thêm đối tác";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-4">Thêm Nhà cung cấp mới</h2>
    <div class="card shadow-sm border-0 col-lg-8">
        <div class="card-body p-4">
            @using (Html.BeginForm())
            {
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên công ty/Cá nhân</label>
                        @Html.TextBoxFor(m => m.SupplierName, new { @class = "form-control", required = "required" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ</label>
                    @Html.TextBoxFor(m => m.Address, new { @class = "form-control" })
                </div>
                <div class="mt-4 text-end">
                    <a href="@Url.Action("Suppliers")" class="btn btn-light border">Hủy</a>
                    <button type="submit" class="btn btn-primary px-5">Lưu thông tin</button>
                </div>
            }
        </div>
    </div>
</div>