@model IEnumerable<Web.Models.Supplier>
@{
    ViewBag.Title = "Danh sách Nhà cung cấp";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mt-4">Đối tác cung ứng</h2>
        <a href="@Url.Action("CreateSupplier")" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm đối tác</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Tên nhà cung cấp</th>
                        <th>Điện thoại</th>
                        <th>Địa chỉ</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.SupplierName</strong></td>
                            <td>@item.Phone</td>
                            <td>@item.Address</td>
                            <td class="text-end">
                                <a href="#" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                                <a href="#" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>