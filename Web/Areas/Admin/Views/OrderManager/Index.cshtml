@model IEnumerable<Web.Models.Order>
@{
    ViewBag.Title = "Quản lý Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-4">Quản lý Đơn hàng</h2>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted text-uppercase small">
                        <tr>
                            <th class="ps-4">Mã ĐH</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">#@item.Id/td>
                                <td>@(item.Date.HasValue ? item.Date.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")</td>
                                <td class="fw-bold text-dark">@string.Format("{0:N0} đ", item.Total)</td>
                                <td>
                                    @using (Html.BeginForm("UpdateStatus", "OrderManager", new { id = item.Id }, FormMethod.Post))
                                    {
                                        <select name="status" onchange="this.form.submit()" class="form-select form-select-sm w-auto">
                                            <option value="Pending" selected="@(item.Status == "Pending")">Chờ duyệt</option>
                                            <option value="Processing" selected="@(item.Status == "Processing")">Đang làm</option>
                                            <option value="Completed" selected="@(item.Status == "Completed")">Hoàn thành</option>
                                            <option value="Cancelled" selected="@(item.Status == "Cancelled")">Đã huỷ</option>
                                        </select>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-info text-white">
                                        <i class="fas fa-eye me-1"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>