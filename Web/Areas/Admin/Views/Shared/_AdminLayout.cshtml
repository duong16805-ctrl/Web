<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Quản trị Hệ thống Coffee</title>

    <!-- CSS: Google Fonts & Bootstrap 5 & FontAwesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary: #5d4037;
            --secondary: #8d6e63;
            --sidebar-bg: #2b1d1a;
            --accent: #ffab91;
            --body-bg: #f8f9fa;
        }

        body { font-family: 'Inter', sans-serif; background-color: var(--body-bg); overflow-x: hidden; }

        /* Sidebar Styling */
        .sidebar {
            width: 260px; height: 100vh; background: var(--sidebar-bg);
            position: fixed; left: 0; top: 0; color: white; transition: all 0.3s;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1); z-index: 1000;
        }
        .sidebar-brand { padding: 25px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .nav-link {
            color: #bcaaa4; padding: 14px 25px; display: flex; align-items: center;
            text-decoration: none; border-radius: 0 50px 50px 0; margin: 4px 0;
            transition: all 0.2s;
        }
        .nav-link:hover, .nav-link.active { background: var(--primary); color: white; }
        .nav-link i { width: 25px; font-size: 1.1rem; margin-right: 12px; }

        /* Main Content */
        .main-content { margin-left: 260px; padding: 30px; transition: all 0.3s; }

        /* Modern Cards */
        .card-stats {
            border: none; border-radius: 16px; transition: transform 0.3s;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        .card-stats:hover { transform: translateY(-5px); }

        .btn-custom { border-radius: 10px; font-weight: 600; padding: 10px 20px; transition: 0.3s; }
        .btn-primary-coffee { background: var(--primary); color: white; border: none; }
        .btn-primary-coffee:hover { background: var(--sidebar-bg); color: white; }

        /* Table Styling */
        .table-container { background: white; border-radius: 16px; padding: 25px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .table thead th { background: #fdfaf9; color: var(--primary); border: none; font-weight: 700; text-transform: uppercase; font-size: 0.75rem; }

        @@media (max-width: 992px) {
            .sidebar { left: -260px; }
            .main-content { margin-left: 0; }
            .sidebar.active { left: 0; }
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <h4 class="fw-bold mb-0 text-white"><i class="fas fa-mug-hot me-2 text-accent"></i>THIDUN COFFEE</h4>
            <small class="text-muted">Hệ thống quản trị v1.0</small>
        </div>
        <div class="py-4">
            <a href='@Url.Action("Index", "Dashboard", new { area = "Admin" })'class="nav-link active"><i class="fas fa-home"></i> Tổng quan</a>
            <a href="#" class="nav-link"><i class="fas fa-utensils"></i> Thực đơn</a>
            <a href="#" class="nav-link"><i class="fas fa-tags"></i> Danh mục</a>
            <a href="#" class="nav-link"><i class="fas fa-chair"></i> Bàn cafe</a>
            <a href="#" class="nav-link"><i class="fas fa-shopping-cart"></i> Đơn hàng</a>
            <hr class="mx-3 opacity-25">
            <a href='@Url.Action("Logout", "Account", new { area = "" })' class="nav-link text-danger"><i class="fas fa-power-off"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <!-- Top Nav -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-dark">@ViewBag.Title</h3>
            <div class="d-flex align-items-center">
                <div class="dropdown">
                    <button class="btn btn-white shadow-sm rounded-pill px-3 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-user-circle me-2"></i> Adminstrator
                    </button>
                    <ul class="dropdown-menu border-0 shadow mt-2">
                        <li><a class="dropdown-item" href="#"><i class="fas fa-cog me-2"></i>Cài đặt</a></li>
                        <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i>Thoát</a></li>
                    </ul>
                </div>
            </div>
        </div>

        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @RenderSection("scripts", required: false)
</body>
</html></html>