@model IEnumerable<Web.Models.TableCafe>
@{
    ViewBag.Title = "Sơ đồ Bàn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mt-4">Sơ đồ Bàn Coffee</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary shadow-sm"><i class="fas fa-plus"></i> Thêm bàn</a>
    </div>

    <div class="row">
        @foreach (var table in Model)
        {
            <div class="col-md-3 col-lg-2 mb-4">
                <div class="card h-100 shadow-sm @(table.Status == "Có khách" ? "border-danger text-danger bg-light" : "border-success text-success")" style="border-radius: 15px">

                    <div class="card-body text-center p-4">
                        <i class="fas fa-mug-hot fa-3x mb-3"></i>
                        <h5 class="card-title fw-bold mb-1">@table.Name</h5>
                        <p class="small mb-3">@(table.Status == "Có khách" ? "Đang có khách" : "Bàn trống")</p>

                        <div class="d-grid gap-2">
                            <a href="@Url.Action("ToggleStatus", "TableManager", new { id = table.Id })"
                               class="btn btn-sm @(table.Status == "Có khách" ? "btn-danger" : "btn-success")">
                                @(table.Status == "Có khách" ? "Trả bàn" : "Mở bàn")
                            </a>

                            @* Bước 5: Sửa TableID thành Id cho nút Xóa *@
                            <a href="@Url.Action("Delete", "TableManager", new { id = table.Id })"
                               class="text-muted small text-decoration-none"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa bàn này?')">Xóa bàn</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>