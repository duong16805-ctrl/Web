@model IEnumerable<Web.Models.TableCafe>
@{
    ViewBag.Title = "Sơ đồ Bàn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mt-4">Sơ đồ Bàn Coffee</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary shadow-sm"><i class="fas fa-plus"></i> Thêm bàn</a>
    </div>

    <div class="row">
        @foreach (var table in Model)
        {
            <div class="col-md-3 col-lg-2 mb-4">
                <div class="card h-100 shadow-sm @(table.IsOccupied ? "border-danger text-danger bg-light" : "border-success text-success")" style="border-radius: 15px;">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-mug-hot fa-3x mb-3"></i>
                        <h5 class="card-title fw-bold mb-1">@table.TableName</h5>
                        <p class="small mb-3">@(table.IsOccupied ? "Có khách" : "Bàn trống")</p>
                        <div class="d-grid gap-2">
                            <a href="@Url.Action("ToggleStatus", new { id = table.TableID })" class="btn btn-sm @(table.IsOccupied ? "btn-danger" : "btn-success")">Đổi trạng thái</a>
                            <a href="@Url.Action("Delete", new { id = table.TableID })" class="text-muted small text-decoration-none" onclick="return confirm('Xóa bàn này?')">Xóa bàn</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>