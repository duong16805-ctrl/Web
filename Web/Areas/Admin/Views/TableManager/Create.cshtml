@model Web.Models.TableCafe
@{
    ViewBag.Title = "Thêm bàn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-4">Thêm bàn Coffee mới</h2>
    <div class="card shadow-sm border-0 col-md-6">
        <div class="card-body p-4">
            @using (Html.BeginForm())
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên/Số bàn</label>
                    @Html.TextBoxFor(m => m.TableName, new { @class = "form-control", placeholder = "Ví dụ: Bàn 01", required = "required" })
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Vị trí/Ghi chú</label>
                    <textarea class="form-control" rows="2" placeholder="Ví dụ: Tầng 2 - Cạnh cửa sổ"></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Xác nhận thêm bàn</button>
                <div class="text-center mt-3">
                    <a href="@Url.Action("Index")" class="text-muted small text-decoration-none">Quay lại sơ đồ</a>
                </div>
            }
        </div>
    </div>
</div>
