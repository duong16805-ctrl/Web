@model IEnumerable<Web.Models.Product>
@{
    ViewBag.Title = "Quản lý Thực đơn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mt-4">Quản lý Thực đơn</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus"></i> Thêm món mới
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted text-uppercase small">
                        <tr>
                            <th class="ps-4">Hình ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá bán</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <img src="@item.Image" class="rounded shadow-sm" style="width:50px; height:50px; object-fit:cover;"
                                         onerror="this.src='https://via.placeholder.com/50'" />
                                </td>
                                <td><span class="fw-bold text-dark">@item.Name</span></td>
                                <td><span class="badge bg-light text-secondary border">@(item.Category?.Name ?? "Chưa phân loại")</span></td>
                                <td class="text-danger fw-bold">@string.Format("{0:N0} đ", item.Price)</td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-outline-warning me-1">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.Id})" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Xác nhận xóa món này?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>