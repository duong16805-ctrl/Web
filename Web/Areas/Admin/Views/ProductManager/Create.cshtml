@model Web.Models.Product
@{
    ViewBag.Title = "Thêm món mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-4">Thêm món mới</h2>
    <div class="card shadow-sm border-0 col-lg-8">
        <div class="card-body p-4">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm</label>
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Ví dụ: Cafe Muối", required = "required" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Danh mục</label>
                        @Html.DropDownListFor(m => m.CategoryId, (IEnumerable<SelectListItem>)ViewBag.CategoryId, "-- Chọn danh mục --", new { @class = "form-select" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                        @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", required = "required" })
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Đường dẫn ảnh (URL)</label>
                    @Html.TextBoxFor(m => m.Image, new { @class = "form-control", placeholder = "https://link-anh-cua-ban.jpg" })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả món</label>
                    @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3" })
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary px-5">Lưu lại</button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-2">Hủy bỏ</a>
                </div>
            }
        </div>
    </div>
</div>
